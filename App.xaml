<Application x:Class="BudgetApp.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:BudgetApp"
             xmlns:utility="clr-namespace:BudgetApp.Model.Utility">
    <Application.Resources>
        <!-- Utility Resources -->
        <utility:EnumDescriptionConverter x:Key="EnumDescriptionConverter"/>

        <!-- Styles
        <Style TargetType="TextBlock" x:Key="Title">
            <Setter Property="FontSize" Value="24"/>
            <Setter Property="FontWeight" Value="Bold"/>
        </Style>
        <Style TargetType="Button">
             <Setter Property="Padding" Value="5"/>
         </Style>
        <Style TargetType="TextBox">
            <Setter Property="Padding" Value="2"/>
        </Style>
        -->

        <!-- Data Table Styling -->
        <Style TargetType="DataGridColumnHeader">
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
        </Style>
        <Style TargetType="TextBlock" x:Key="CenteredDataGridCell">
            <Setter Property="TextAlignment" Value="Center"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
        </Style>
