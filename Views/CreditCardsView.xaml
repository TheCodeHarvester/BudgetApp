<UserControl x:Class="BudgetApp.Views.CreditCardsView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:utility="clr-namespace:BudgetApp.Model.Utility"
        mc:Ignorable="d">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="auto"/>
        </Grid.RowDefinitions>

        <TextBlock
            Grid.Row="0"
            FontSize="24"
            Text="Credit Card Accounts"
            HorizontalAlignment="Center"/>

        <Grid
            Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="auto"/>
                <ColumnDefinition Width="auto"/>
                <ColumnDefinition Width="auto"/>
            </Grid.ColumnDefinitions>

            <Grid 
                Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="auto"/>
                    <RowDefinition Height="auto"/>
                </Grid.RowDefinitions>

                <GroupBox
                    Grid.Row="0">
                    <GroupBox.Header>
                        Credit Card Accounts
                    </GroupBox.Header>
        
                    <StackPanel>
                        <DataGrid 
                            Width="400"
                            Margin="0 5 0 0"
                            SelectionMode="Single"
                            ItemsSource="{Binding CreditCardAccounts}"
                            SelectedItem="{Binding SelectedCreditCard, Mode=TwoWay}"
                            AutoGenerateColumns="False"
                            CanUserResizeColumns="False"
                            HeadersVisibility="Column"
                            IsReadOnly="True">
                            <DataGrid.Columns>
                                <DataGridTextColumn
                                    Header="Owner"
                                    Binding="{Binding OwnerName}"
                                    Width="199"
                                    ElementStyle="{StaticResource CenteredDataGridCell}"/>
                                <DataGridTextColumn 
                                    Header="Account Name"
                                    Binding="{Binding AccountName}"
                                    Width="199"
                                    ElementStyle="{StaticResource CenteredDataGridCell}"/>
                            </DataGrid.Columns>
                        </DataGrid>
        
                        <StackPanel
                            Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            Margin="0 -1 0 0">
                            <Button 
                                Command="{Binding AddCreditCardCommand}"
                                ContentTemplate="{StaticResource PlusButtonContentTemplate}"/>
                            <Button
                                Command="{Binding RemoveCreditCardCommand}"
                                Margin="1 0 0 0"
                                ContentTemplate="{StaticResource MinusButtonContentTemplate}"/>
                        </StackPanel>
                    </StackPanel>
                </GroupBox>
            </Grid>

            <!-- Selected Credit Card Account Section -->
            <StackPanel
                Grid.Column="1"
                Margin="5 0 0 0"
                Grid.IsSharedSizeScope="True">
    
                <!-- Account Information Group Box -->
                <GroupBox>
                    <GroupBox.Header>
                        Account Information
                    </GroupBox.Header>
    
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="auto"/>
                            <RowDefinition Height="auto"/>
                            <RowDefinition Height="auto"/>
                            <RowDefinition Height="auto"/>
                            <RowDefinition Height="auto"/>
                            <RowDefinition Height="auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="auto" SharedSizeGroup="FirstColumnGroup"/>
                            <ColumnDefinition Width="200"/>
                            <ColumnDefinition Width="30"/>
                            <ColumnDefinition Width="30"/>
                        </Grid.ColumnDefinitions>
    
                        <!-- Column 1 -->
                        <TextBlock
                            Grid.Row="0"
                            Grid.Column="0"
                            Text="Owner"/>
                        <TextBlock
                            Grid.Row="1"
                            Grid.Column="0"
                            Margin="0 5 0 0"
                            Text="Account Name"/>
                        <TextBlock
                            Grid.Row="2"
                            Grid.Column="0"
                            Margin="0 5 0 0"
                            Text="Credit Card #"/>
                        <TextBlock
                            Grid.Row="3"
                            Grid.Column="0"
                            Margin="0 5 0 0"
                            Text="ccv"/>
                        <TextBlock
                            Grid.Row="4"
                            Grid.Column="0"
                            Margin="0 5 0 0"
                            Text="Cycle Date"/>
                        <TextBlock
                            Grid.Row="5"
                            Grid.Column="0"
                            Margin="0 5 0 0"
                            Text="Expiration Date"/>
    
                        <!-- Column 2 -->
                        <ComboBox
                            Grid.Row="0"
                            Grid.Column="1"
                            Margin="5 0 0 0"
                            ItemsSource="{Binding People}"
                            SelectedValuePath="Id"
                            SelectedValue="{Binding SelectedCreditCard.OwnerId,
                            Mode=TwoWay}">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding FullName}"/>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                        <TextBox
                            Grid.Row="1" 
                            Grid.Column="1"
                            Margin="5 5 0 0"
                            Text="{Binding SelectedCreditCard.AccountName, 
                            TargetNullValue='',
                            UpdateSourceTrigger=PropertyChanged}"/>
                        <TextBox
                            Grid.Row="2" 
                            Grid.Column="1"
                            Margin="5 5 0 0"
                            Text="{Binding AccountDetails.AccountNumber, 
                            TargetNullValue='',
                            Mode=TwoWay,
                            UpdateSourceTrigger=PropertyChanged}"/>
                        <TextBox
                            Grid.Row="3" 
                            Grid.Column="1"
                            Margin="5 5 0 0"
                            Text="{Binding AccountDetails.CCV, 
                            TargetNullValue='',
                            UpdateSourceTrigger=PropertyChanged}"/>
                        <TextBox 
                            Grid.Row="4"
                            Grid.Column="1"
                            Margin="5 5 0 0"
                            Text="{Binding SelectedCreditCard.Account.CycleDay, 
                            UpdateSourceTrigger=PropertyChanged}"/>
                        <DatePicker 
                            Grid.Row="5"
                            Grid.Column="1"
                            Margin="5 5 0 0"
                            SelectedDate="{Binding SelectedCreditCard.Account.ExpirationDate,
                            TargetNullValue='',
                            Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
    
                        <!-- Column 3 -->
                        <Button 
                            Grid.Row="2"
                            Grid.Column="2"
                            Margin="5 5 0 0"
                            Command="{Binding RemoveCreditCardCommand}"
                            Content="👁"/>
    
                        <!-- Column 4 -->
                        <Button 
                            Grid.Row="2"
                            Grid.Column="3"
                            Margin="5 5 0 0"
                            Command="{Binding RemoveCreditCardCommand}"
                            Content="📝"/>
                    </Grid>
                </GroupBox>
    
                <!-- Login Information Group Box -->
                <GroupBox
                    Margin="0 10 0 0">
                    <GroupBox.Header>
                        Login Information
                    </GroupBox.Header>
    
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="auto"/>
                            <RowDefinition Height="auto"/>
                            <RowDefinition Height="auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="auto" SharedSizeGroup="FirstColumnGroup"/>
                            <ColumnDefinition Width="200"/>
                            <ColumnDefinition Width="30"/>
                            <ColumnDefinition Width="30"/>
                        </Grid.ColumnDefinitions>
    
                        <!-- Column 1 -->
                        <TextBlock
                            Grid.Row="0"
                            Grid.Column="0"
                            Text="Username"/>
                        <TextBlock
                            Grid.Row="1"
                            Grid.Column="0"
                            Margin="0 5 0 0"
                            Text="Password"/>
                        <TextBlock
                            Grid.Row="2"
                            Grid.Column="0"
                            Margin="0 5 0 0"
                            Text="Website URL"/>
    
                        <!-- Column 2 -->
                        <TextBox
                            Grid.Row="0" 
                            Grid.Column="1"
                            Margin="5 0 0 0"
                            Text="{Binding LoginDetails.Username,
                            TargetNullValue='',
                            UpdateSourceTrigger=PropertyChanged}"/>
                        <TextBox
                            Grid.Row="1" 
                            Grid.Column="1"
                            Margin="5 5 0 0"
                            Text="{Binding LoginDetails.Password,
                            TargetNullValue='',
                            UpdateSourceTrigger=PropertyChanged}"/>
                        <TextBox
                            Grid.Row="2" 
                            Grid.Column="1"
                            Margin="5 5 0 0"
                            Text="{Binding LoginDetails.WebsiteURL,
                            TargetNullValue='',
                            UpdateSourceTrigger=PropertyChanged}"/>
    
                        <!-- Column 3 -->
                        <Button 
                            Grid.Row="0"
                            Grid.Column="2"
                            Margin="5 0 0 0"
                            Command="{Binding RemoveCreditCardCommand}"
                            Content="&#xf070;"/>
                        <Button 
                            Grid.Row="1"
                            Grid.Column="2"
                            Margin="5 5 0 0"
                            Command="{Binding RemoveCreditCardCommand}"
                            Content="👁"/>
                        <Button 
                            Grid.Row="2"
                            Grid.Column="2"
                            Margin="5 5 0 0"
                            Command="{Binding RemoveCreditCardCommand}"
                            Content="🌐"/>
                        
                        <!-- Column 4 -->
                        <Button 
                            Grid.Row="0"
                            Grid.Column="3"
                            Margin="5 0 0 0"
                            Command="{Binding RemoveCreditCardCommand}"
                            Content="📝"/>
                        <Button 
                            Grid.Row="1"
                            Grid.Column="3"
                            Margin="5 5 0 0"
                            Command="{Binding RemoveCreditCardCommand}"
                            Content="📝"/>
                    </Grid>
                </GroupBox>
    
                <!-- Money Information Group Box -->
                <GroupBox
                    Margin="0 10 0 0">
                    <GroupBox.Header>
                        Money Information
                    </GroupBox.Header>
    
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="auto"/>
                            <RowDefinition Height="auto"/>
                            <RowDefinition Height="auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="auto" 
                                              SharedSizeGroup="FirstColumnGroup"/>
                            <ColumnDefinition Width="200"/>
                        </Grid.ColumnDefinitions>
    
                        <!-- Column 1 -->
                        <TextBlock
                            Grid.Row="0"
                            Grid.Column="0"
                            Text="Credit Line"/>
                        <TextBlock
                            Grid.Row="1"
                            Grid.Column="0"
                            Margin="0 5 0 0"
                            Text="Balance"/>
                        <TextBlock
                            Grid.Row="2"
                            Grid.Column="0"
                            Margin="0 5 0 0"
                            Text="Available"/>
    
                        <!-- Column 2 -->
                        <TextBox
                            Grid.Row="0" 
                            Grid.Column="1"
                            Margin="5 0 0 0"
                            Style="{StaticResource LoseFocusOnEnter}"
                            Text="{Binding SelectedCreditCard.Account.CreditLine,
                            TargetNullValue='',
                            StringFormat={}{0:C},
                            UpdateSourceTrigger=LostFocus}"/>
                        <TextBox
                            Grid.Row="1"
                            Grid.Column="1"
                            Margin="5 5 0 0"
                            Style="{StaticResource LoseFocusOnEnter}"
                            Text="{Binding SelectedCreditCard.Account.Balance,
                            TargetNullValue='',
                            StringFormat={}{0:C},
                            UpdateSourceTrigger=LostFocus}"/>
                        <TextBlock
                            Grid.Row="2"
                            Grid.Column="1"
                            Margin="5 5 0 0"
                            Text="{Binding SelectedCreditCard.Account.Available,
                            TargetNullValue='',
                            StringFormat={}{0:C},
                            UpdateSourceTrigger=PropertyChanged}"/>
                    </Grid>
                </GroupBox>
                
                <GroupBox>
                    <GroupBox.Header>
                        Interests
                    </GroupBox.Header>
                    
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="auto"/>
                            <RowDefinition Height="auto"/>
                        </Grid.RowDefinitions>
                        
                        <StackPanel
                            Grid.Row="1">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="auto"/>
                                    <ColumnDefinition Width="145"/>
                                    <ColumnDefinition Width="auto"/>
                                    <ColumnDefinition Width="95"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock
                                    Grid.Column="0"
                                    Text="Name"/>
                                <TextBox
                                    Grid.Column="1"
                                    Margin="5 0 0 0"
                                    Text="{Binding SelectedInterest.Name, 
                                Mode=TwoWay,
                                TargetNullValue='',
                                UpdateSourceTrigger=PropertyChanged}"
                                    IsEnabled="{Binding SelectedInterest}"/>

                                <TextBlock
                                    Grid.Column="2"
                                    Text="Percentage"
                                    Margin="5 0 0 0"/>
                                <TextBox
                                    Grid.Column="3"
                                    Margin="5 0 0 0"
                                    Style="{StaticResource LoseFocusOnEnter}"
                                    Text="{Binding SelectedInterest.Percentage,
                                    Mode=TwoWay,
                                    TargetNullValue='',
                                    StringFormat={}{0:F2},
                                    UpdateSourceTrigger=LostFocus}"
                                    PreviewTextInput="NumberValidationTextBox"/>
                            </Grid>

                            <StackPanel>
                                <DataGrid
                                    Margin="0 5 0 0"
                                    SelectionMode="Single"
                                    ItemsSource="{Binding SelectedCreditCard.Account.Interests}"
                                    SelectedItem="{Binding SelectedInterest, Mode=TwoWay}"
                                    AutoGenerateColumns="False"
                                    CanUserResizeColumns="False"
                                    HeadersVisibility="Column"
                                    IsReadOnly="True">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn
                                            Header="Name"
                                            MinWidth="177"
                                            Binding="{Binding Name}"
                                            ElementStyle="{StaticResource CenteredDataGridCell}"/>
                                        <DataGridTextColumn 
                                            Header="Percentage"
                                            MinWidth="177"
                                            Binding="{Binding Percentage, StringFormat={}{0:#0.00'%'}}"
                                            ElementStyle="{StaticResource CenteredDataGridCell}"/>
                                    </DataGrid.Columns>
                                </DataGrid>

                                <StackPanel
                                    Orientation="Horizontal"
                                    HorizontalAlignment="Right"
                                    Margin="0 -1 0 0">
                                    <Button 
                                        Command="{Binding AddInterestCommand}"
                                        ContentTemplate="{StaticResource PlusButtonContentTemplate}"/>
                                    <Button
                                        Command="{Binding RemoveInterestCommand}"
                                        Margin="1 0 0 0"
                                        ContentTemplate="{StaticResource MinusButtonContentTemplate}"/>
                                </StackPanel>
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                </GroupBox>
            </StackPanel>

            <!-- Selected Credit Card Notes Section -->
            <Grid
                Grid.Column="2"
                Margin="5 0 0 0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="auto"/>
                </Grid.RowDefinitions>

                <GroupBox
                    Grid.Row="0">
                    <GroupBox.Header>
                        Credit Card Notes
                    </GroupBox.Header>
                    <StackPanel>
                        <DataGrid
                            Margin="0 5 0 0"
                            SelectionMode="Single"
                            ItemsSource="{Binding SelectedCreditCard.Account.Notes}"
                            SelectedItem="{Binding SelectedNote, Mode=TwoWay}"
                            AutoGenerateColumns="False"
                            CanUserResizeColumns="False"
                            CanUserAddRows="False"
                            CanUserDeleteRows="False"
                            HeadersVisibility="Column"
                            Style="{StaticResource SingleClickEditDataCell}">
                            <DataGrid.Columns>
                                <DataGridTemplateColumn Header="Notes" MinWidth="400">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Description}" />
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>

                                    <DataGridTemplateColumn.CellEditingTemplate>
                                        <DataTemplate>
                                            <TextBox Text="{Binding Description, UpdateSourceTrigger=PropertyChanged}"
                                                     AcceptsReturn="True"
                                                     TextWrapping="Wrap"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellEditingTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>

                        <StackPanel
                            Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            Margin="0 -1 0 0">
                            <Button 
                                Command="{Binding AddNoteCommand}"
                                ContentTemplate="{StaticResource PlusButtonContentTemplate}"/>
                            <Button
                                Command="{Binding RemoveNoteCommand}"
                                Margin="1 0 0 0"
                                ContentTemplate="{StaticResource MinusButtonContentTemplate}"/>
                        </StackPanel>
                    </StackPanel>
                </GroupBox>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
