<UserControl x:Class="BudgetApp.Views.CreditCardsAccountsView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        mc:Ignorable="d">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="auto"/>
        </Grid.RowDefinitions>

        <TextBlock
            Grid.Row="0"
            FontSize="24"
            Text="Credit Card Accounts"
            HorizontalAlignment="Center"/>

        <Grid
            Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="auto"/>
                <ColumnDefinition Width="auto"/>
                <ColumnDefinition Width="auto"/>
            </Grid.ColumnDefinitions>

            <Grid 
                Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="auto"/>
                    <RowDefinition Height="auto"/>
                </Grid.RowDefinitions>

                <GroupBox
                    Grid.Row="0">
                    <GroupBox.Header>
                        Credit Card Accounts
                    </GroupBox.Header>
        
                    <StackPanel>
                        <DataGrid 
                            Width="400"
                            Margin="0 5 0 0"
                            SelectionMode="Single"
                            ItemsSource="{Binding CreditCardAccounts}"
                            SelectedItem="{Binding SelectedCreditCardAccount, Mode=TwoWay}"
                            AutoGenerateColumns="False"
                            CanUserResizeColumns="False"
                            HeadersVisibility="Column"
                            IsReadOnly="True">
                            <DataGrid.Columns>
                                <DataGridTextColumn
                                    Header="Owner"
                                    Binding="{Binding OwnerName}"
                                    Width="199"
                                    ElementStyle="{StaticResource CenteredDataGridCell}"/>
                                <DataGridTextColumn 
                                    Header="Account Name"
                                    Binding="{Binding AccountName}"
                                    Width="199"
                                    ElementStyle="{StaticResource CenteredDataGridCell}"/>
                            </DataGrid.Columns>
                        </DataGrid>
        
                        <StackPanel
                            Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            Margin="0 -1 0 0">
                            <Button 
                                Command="{Binding AddCreditCardAccountCommand}"
                                ContentTemplate="{StaticResource PlusButtonContentTemplate}"/>
                            <Button
                                Command="{Binding RemoveCreditCardAccountCommand}"
                                Margin="1 0 0 0"
                                ContentTemplate="{StaticResource MinusButtonContentTemplate}"/>
                        </StackPanel>
                    </StackPanel>
                </GroupBox>
            </Grid>

            <!-- Selected Credit Card Account Section -->
            <StackPanel
                Grid.Column="1"
                Margin="5 0 0 0"
                Grid.IsSharedSizeScope="True">
    
                <!-- Account Information Group Box -->
                <GroupBox>
                    <GroupBox.Header>
                        Account Information
                    </GroupBox.Header>
    
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="auto"/>
                            <RowDefinition Height="auto"/>
                            <RowDefinition Height="auto"/>
                            <RowDefinition Height="auto"/>
                            <RowDefinition Height="auto"/>
                            <RowDefinition Height="auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="auto" SharedSizeGroup="FirstColumnGroup"/>
                            <ColumnDefinition Width="200"/>
                            <ColumnDefinition Width="30"/>
                            <ColumnDefinition Width="30"/>
                        </Grid.ColumnDefinitions>
    
                        <!-- Column 1 -->
                        <TextBlock
                            Grid.Row="0"
                            Grid.Column="0"
                            Text="Owner"/>
                        <TextBlock
                            Grid.Row="1"
                            Grid.Column="0"
                            Margin="0 5 0 0"
                            Text="Account Name"/>
                        <TextBlock
                            Grid.Row="2"
                            Grid.Column="0"
                            Margin="0 5 0 0"
                            Text="Credit Card #"/>
                        <TextBlock
                            Grid.Row="3"
                            Grid.Column="0"
                            Margin="0 5 0 0"
                            Text="CCV"/>
                        <TextBlock
                            Grid.Row="4"
                            Grid.Column="0"
                            Margin="0 5 0 0"
                            Text="Cycle Date"/>
                        <TextBlock
                            Grid.Row="5"
                            Grid.Column="0"
                            Margin="0 5 0 0"
                            Text="Expiration Date"/>
    
                        <!-- Column 2 -->
                        <ComboBox
                            Grid.Row="0"
                            Grid.Column="1"
                            Margin="5 0 0 0"
                            ItemsSource="{Binding People}"
                            SelectedValuePath="Id"
                            SelectedValue="{Binding SelectedCreditCardAccount.OwnerId,
                            Mode=TwoWay}">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding FullName}"/>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                        <TextBox
                            Grid.Row="1" 
                            Grid.Column="1"
                            Margin="5 5 0 0"
                            Text="{Binding SelectedCreditCardAccount.AccountName, 
                            TargetNullValue='',
                            UpdateSourceTrigger=PropertyChanged}"/>
                        <TextBox
                            Grid.Row="2" 
                            Grid.Column="1"
                            Margin="5 5 0 0"
                            Text="{Binding AccountDetails.AccountNumber, 
                            TargetNullValue='',
                            Mode=TwoWay,
                            UpdateSourceTrigger=PropertyChanged}"/>
                        <TextBox
                            Grid.Row="3" 
                            Grid.Column="1"
                            Margin="5 5 0 0"
                            Text="{Binding AccountDetails.CCV, 
                            TargetNullValue='',
                            UpdateSourceTrigger=PropertyChanged}"/>
                        <TextBox 
                            Grid.Row="4"
                            Grid.Column="1"
                            Margin="5 5 0 0"
                            Text="{Binding SelectedCreditCardAccount.Account.CycleDay, 
                            UpdateSourceTrigger=PropertyChanged}"/>
                        <DatePicker 
                            Grid.Row="5"
                            Grid.Column="1"
                            Margin="5 5 0 0"
                            SelectedDate="{Binding SelectedCreditCardAccount.Account.ExpirationDate,
                            TargetNullValue='',
                            Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
    
                        <!-- Column 3 -->
                        <Button 
                            Grid.Row="2"
                            Grid.Column="2"
                            Margin="5 5 0 0"
                            Command="{Binding RemoveCreditCardAccountCommand}"
                            Content="👁"/>
    
                        <!-- Column 4 -->
                        <Button 
                            Grid.Row="2"
                            Grid.Column="3"
                            Margin="5 5 0 0"
                            Command="{Binding RemoveCreditCardAccountCommand}"
                            Content="📝"/>
                    </Grid>
                </GroupBox>
    
                <!-- Login Information Group Box -->
                <GroupBox
                    Margin="0 10 0 0">
                    <GroupBox.Header>
                        Login Information
                    </GroupBox.Header>
    
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="auto"/>
                            <RowDefinition Height="auto"/>
                            <RowDefinition Height="auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="auto" SharedSizeGroup="FirstColumnGroup"/>
                            <ColumnDefinition Width="200"/>
                            <ColumnDefinition Width="30"/>
                            <ColumnDefinition Width="30"/>
                        </Grid.ColumnDefinitions>
    
                        <!-- Column 1 -->
                        <TextBlock
                            Grid.Row="0"
                            Grid.Column="0"
                            Text="Username"/>
                        <TextBlock
                            Grid.Row="1"
                            Grid.Column="0"
                            Margin="0 5 0 0"
                            Text="Password"/>
                        <TextBlock
                            Grid.Row="2"
                            Grid.Column="0"
                            Margin="0 5 0 0"
                            Text="Website URL"/>
    
                        <!-- Column 2 -->
                        <TextBox
                            Grid.Row="0" 
                            Grid.Column="1"
                            Margin="5 0 0 0"
                            Text="{Binding LoginDetails.Username,
                            TargetNullValue='',
                            UpdateSourceTrigger=PropertyChanged}"/>
                        <TextBox
                            Grid.Row="1" 
                            Grid.Column="1"
                            Margin="5 5 0 0"
                            Text="{Binding LoginDetails.Password,
                            TargetNullValue='',
                            UpdateSourceTrigger=PropertyChanged}"/>
                        <TextBox
                            Grid.Row="2" 
                            Grid.Column="1"
                            Margin="5 5 0 0"
                            Text="{Binding LoginDetails.WebsiteURL,
                            TargetNullValue='',
                            UpdateSourceTrigger=PropertyChanged}"/>
    
                        <!-- Column 3 -->
                        <Button 
                            Grid.Row="0"
                            Grid.Column="2"
                            Margin="5 0 0 0"
                            Command="{Binding RemoveCreditCardAccountCommand}"
                            Content="👁"/>
                        <Button 
                            Grid.Row="1"
                            Grid.Column="2"
                            Margin="5 5 0 0"
                            Command="{Binding RemoveCreditCardAccountCommand}"
                            Content="👁"/>
                        <Button 
                            Grid.Row="2"
                            Grid.Column="2"
                            Margin="5 5 0 0"
                            Command="{Binding RemoveCreditCardAccountCommand}"
                            Content="🌐"/>
                        
                        <!-- Column 4 -->
                        <Button 
                            Grid.Row="0"
                            Grid.Column="3"
                            Margin="5 0 0 0"
                            Command="{Binding RemoveCreditCardAccountCommand}"
                            Content="📝"/>
                        <Button 
                            Grid.Row="1"
                            Grid.Column="3"
                            Margin="5 5 0 0"
                            Command="{Binding RemoveCreditCardAccountCommand}"
                            Content="📝"/>
                    </Grid>
                </GroupBox>
    
                <!-- Money Information Group Box -->
                <GroupBox
                    Margin="0 10 0 0">
                    <GroupBox.Header>
                        Money Information
                    </GroupBox.Header>
    
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="auto"/>
                            <RowDefinition Height="auto"/>
                            <RowDefinition Height="auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="auto" SharedSizeGroup="FirstColumnGroup"/>
                            <ColumnDefinition Width="200"/>
                        </Grid.ColumnDefinitions>
    
                        <!-- Column 1 -->
                        <TextBlock
                            Grid.Row="0"
                            Grid.Column="0"
                            Text="Credit Line"/>
                        <TextBlock
                            Grid.Row="1"
                            Grid.Column="0"
                            Margin="0 5 0 0"
                            Text="Balance"/>
                        <TextBlock
                            Grid.Row="2"
                            Grid.Column="0"
                            Margin="0 5 0 0"
                            Text="Available"/>
    
                        <!-- Column 2 -->
                        <TextBox
                            Grid.Row="0" 
                            Grid.Column="1"
                            Margin="5 0 0 0"
                            Text="{Binding SelectedCreditCardAccount.Account.CreditLine,
                            TargetNullValue='',
                            UpdateSourceTrigger=PropertyChanged,
                            StringFormat={}{0:C}}"/>
                        <TextBox
                            Grid.Row="1"
                            Grid.Column="1"
                            Margin="5 5 0 0"
                            Text="{Binding SelectedCreditCardAccount.Account.Balance,
                            TargetNullValue='',
                            UpdateSourceTrigger=PropertyChanged,
                            StringFormat={}{0:C}}"/>
                        <TextBlock
                            Grid.Row="2" 
                            Grid.Column="1"
                            Margin="5 5 0 0"
                            Text="{Binding SelectedCreditCardAccount.Account.Available,
                            TargetNullValue='',
                            UpdateSourceTrigger=PropertyChanged,
                            StringFormat={}{0:C}}"/>
                    </Grid>
                </GroupBox>
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>
