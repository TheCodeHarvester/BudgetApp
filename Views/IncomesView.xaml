<UserControl x:Class="BudgetApp.Views.IncomesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="auto"/>
        </Grid.RowDefinitions>

        <TextBlock
            Grid.Row="0"
            FontSize="24"
            Text="Income"
            HorizontalAlignment="Center"/>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="auto"/>
                <ColumnDefinition Width="auto"/>
            </Grid.ColumnDefinitions>

            <Grid
                Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="auto"/>
                </Grid.RowDefinitions>

                <GroupBox
                    Grid.Column="0">
                    <GroupBox.Header>
                        Income List
                    </GroupBox.Header>
    
                    <StackPanel>
                        <DataGrid
                            Width="600"
                            SelectionMode="Single"
                            ItemsSource="{Binding Incomes}"
                            SelectedItem="{Binding SelectedIncome, Mode=TwoWay}"
                            AutoGenerateColumns="False"
                            CanUserResizeColumns="False"
                            HeadersVisibility="Column"
                            IsReadOnly="True">
                            <DataGrid.Columns>
                                <DataGridTextColumn 
                                    Header="Source"
                                    Binding="{Binding Account.IncomeSource}"
                                    Width="99"
                                    ElementStyle="{StaticResource CenteredDataGridCell}"/>
                                <DataGridTextColumn 
                                    Header="Amount"
                                    Binding="{Binding Account.Amount, StringFormat={}{0:C}}"
                                    Width="99"
                                    ElementStyle="{StaticResource CenteredDataGridCell}"/>
                                <DataGridTextColumn 
                                    Header="Who"
                                    Binding="{Binding OwnerName}"
                                    Width="180"
                                    ElementStyle="{StaticResource CenteredDataGridCell}"/>
                                <DataGridTextColumn 
                                    Header="Occurence Type"
                                    Binding="{Binding Account.OccurenceType, Converter={StaticResource EnumDescriptionConverter}}"
                                    Width="100"
                                    ElementStyle="{StaticResource CenteredDataGridCell}"/>
                                <DataGridTextColumn 
                                    Header="Next Occurence"
                                    Binding="{Binding Account.NextOccurrence, StringFormat=d}"
                                    Width="120"
                                    ElementStyle="{StaticResource CenteredDataGridCell}"/>
                            </DataGrid.Columns>
                        </DataGrid>
            
                        <StackPanel
                            Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            Margin="0 -1 0 0">
                            <Button
                                Command="{Binding AddIncomeCommand}"
                                ContentTemplate="{StaticResource PlusButtonContentTemplate}">
                            </Button>
                            <Button
                                Command="{Binding RemoveIncomeCommand}"
                                Margin="1 0 0 0"
                                ContentTemplate="{StaticResource MinusButtonContentTemplate}">
                            </Button>
                        </StackPanel>
                    </StackPanel>
                </GroupBox>
            </Grid>

            <GroupBox
                Grid.Column="1"
                Margin="5 0 0 0">
                <GroupBox.Header>
                    Income List
                </GroupBox.Header>

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="auto"/>
                        <RowDefinition Height="auto"/>
                        <RowDefinition Height="auto"/>
                        <RowDefinition Height="auto"/>
                        <RowDefinition Height="auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="auto"/>
                        <ColumnDefinition Width="auto" MinWidth="120"/>
                    </Grid.ColumnDefinitions>

                    <!-- First Row -->
                    <TextBlock
                        Grid.Row="0"
                        Grid.Column="0"
                        Text="Source"/>
                    <TextBlock 
                        Grid.Row="1"
                        Grid.Column="0"
                        Margin="0 5 0 0"
                        Text="Amount"/>
                    <TextBlock
                        Grid.Row="2"
                        Grid.Column="0"
                        Margin="0 5 0 0"
                        Text="Who's Income"/>
                    <TextBlock
                        Grid.Row="3"
                        Grid.Column="0"
                        Margin="0 5 0 0"
                        Text="Occurance Type"/>
                    <TextBlock 
                        Grid.Row="4"
                        Grid.Column="0"
                        Margin="0 5 0 0"
                        Text="Next Occurance"/>

                    <!-- Second Column -->
                    <TextBox 
                        Grid.Row="0" 
                        Grid.Column="1"
                        Margin="5 0 0 0"
                        Text="{Binding SelectedIncome.Account.IncomeSource, 
                        UpdateSourceTrigger=PropertyChanged,
                        TargetNullValue=''}"/>
                    <TextBox 
                        Grid.Row="1"
                        Grid.Column="1"
                        Margin="5 5 0 0"
                        Text="{Binding SelectedIncome.Account.Amount, 
                        StringFormat=C, 
                        UpdateSourceTrigger=PropertyChanged,
                        TargetNullValue=''}"
                        PreviewTextInput="NumberValidationTextBox"/>
                    <ComboBox
                        Grid.Row="2"
                        Grid.Column="1"
                        Margin="5 5 0 0"
                        ItemsSource="{Binding People}"
                        SelectedValuePath="Id"
                        SelectedValue="{Binding SelectedIncome.OwnerId,
                        Mode=TwoWay}">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding FullName}"/>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                    <ComboBox
                        Grid.Row="3"
                        Grid.Column="1"
                        Margin="5 5 0 0"
                        ItemsSource="{Binding OccurenceTypes}"
                        SelectedItem="{Binding SelectedIncome.Account.OccurenceType, 
                        Mode=TwoWay,
                        UpdateSourceTrigger=PropertyChanged}">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Converter={StaticResource EnumDescriptionConverter}}"/>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                    <DatePicker 
                        Grid.Row="4"
                        Grid.Column="1"
                        Margin="5 5 0 0"
                        SelectedDate="{Binding SelectedIncome.Account.NextOccurrence, 
                        Mode=TwoWay, 
                        UpdateSourceTrigger=PropertyChanged, 
                        TargetNullValue=''}"/>
                </Grid>
            </GroupBox>
        </Grid>
    </Grid>
</UserControl>
