<UserControl x:Class="BudgetApp.Views.IncomesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:BudgetApp.Views"
             xmlns:utility="clr-namespace:BudgetApp.Model.Utility"
             mc:Ignorable="d">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="auto"/>
        </Grid.RowDefinitions>

        <TextBlock 
            Grid.Row="0"
            FontSize="24"
            Text="Income" />

        <Grid Grid.Row="1" Margin="0 25 0 0"
              utility:FocusHelper.FocusTarget="{Binding FocusTarget}">
            <Grid.RowDefinitions>
                <RowDefinition Height="auto"/>
                <RowDefinition Height="auto"/>
                <RowDefinition Height="auto"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="120"/>
                <ColumnDefinition Width="120"/>
                <ColumnDefinition Width="120"/>
                <ColumnDefinition Width="120"/>
                <ColumnDefinition Width="120"/>
            </Grid.ColumnDefinitions>

            <!-- First Row -->
            <TextBlock
                Grid.Row="0"
                Grid.Column="0"
                Text="Source"/>
            <TextBlock 
                Grid.Row="0"
                Grid.Column="1"
                Margin="5 0 0 0"
                Text="Amount"/>
            <TextBlock
                Grid.Row="0"
                Grid.Column="2"
                Margin="5 0 0 0"
                Text="Who's Income"/>
            <TextBlock
                Grid.Row="0"
                Grid.Column="3"
                Margin="5 0 0 0"
                Text="Occurance Type"/>
            <TextBlock 
                Grid.Row="0"
                Grid.Column="4"
                Margin="5 0 0 0"
                Text="Next Occurance"/>

            <!-- Second Row -->
            <TextBox 
                Grid.Row="1" 
                Grid.Column="0"
                Margin="0 5 0 0"
                Text="{Binding IncomeSource, UpdateSourceTrigger=PropertyChanged}"
                utility:FocusHelper.FocusKey="IncomeSource"
                utility:FocusHelper.MoveCaretToEnd="True"/>
            <TextBox 
                Grid.Row="1"
                Grid.Column="1"
                Margin="5 5 0 0"
                Text="{Binding Amount, StringFormat=C, UpdateSourceTrigger=LostFocus}"
                PreviewTextInput="NumberValidationTextBox"/>
            <ComboBox
                Grid.Row="1"
                Grid.Column="2"
                Margin="5 5 0 0"
                ItemsSource="{Binding People}"
                SelectedItem="{Binding SelectedPerson, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                <ComboBox.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding FullName}"/>
                    </DataTemplate>
                </ComboBox.ItemTemplate>
            </ComboBox>
            <ComboBox
                Grid.Row="1"
                Grid.Column="3"
                Margin="5 5 0 0"
                ItemsSource="{Binding OccurenceTypes}"
                SelectedItem="{Binding OccurenceType, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                <ComboBox.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding Converter={StaticResource EnumDescriptionConverter}}"></TextBlock>
                    </DataTemplate>
                </ComboBox.ItemTemplate>
            </ComboBox>
            <DatePicker 
                Grid.Row="1"
                Grid.Column="4"
                Margin="5 5 0 0"
                SelectedDate="{Binding NextOccurance, 
                Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

            <!-- Third Row -->
            <Button 
                Grid.Row="2"
                Grid.Column="0"
                Margin="0 5 0 0"
                Command="{Binding AddIncomeCommand}"
                Content="Add"
                IsDefault="True"/>
            <Button 
                Grid.Row="2" 
                Grid.Column="1"
                Margin="5 5 0 0"
                Command="{Binding RemoveIncomeCommand}"
                Content="Remove"/>
            <Button 
                Grid.Row="2" 
                Grid.Column="2"
                Margin="5 5 0 0"
                Command="{Binding EditIncomeCommand}"
                Content="Update Income"/>
            <Button 
                Grid.Row="2" 
                Grid.Column="3"
                Margin="5 5 0 0"
                Command="{Binding CancelIncomeCommand}"
                Content="Cancel"/>
        </Grid>

        <DataGrid Grid.Row="3" 
                  Width="600"
                  Margin="0 10 0 0"
                  SelectionMode="Single"
                  ItemsSource="{Binding Incomes}"
                  SelectedItem="{Binding SelectedIncome, Mode=TwoWay}"
                  AutoGenerateColumns="False"
                  CanUserResizeColumns="False"
                  HeadersVisibility="Column"
                  IsReadOnly="True">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Source"
                                    Binding="{Binding IncomeSource}"
                                    Width="99"
                                    ElementStyle="{StaticResource CenteredDataGridCell}"/>
                <DataGridTextColumn Header="Amount"
                                    Binding="{Binding Amount, StringFormat={}{0:C}}"
                                    Width="99"
                                    ElementStyle="{StaticResource CenteredDataGridCell}"/>
                <DataGridTextColumn Header="Who"
                                    Binding="{Binding WhosIncome}"
                                    Width="180"
                                    ElementStyle="{StaticResource CenteredDataGridCell}"/>
                <DataGridTextColumn Header="Occurence Type"
                                    Binding="{Binding OccurenceType, Converter={StaticResource EnumDescriptionConverter}}"
                                    Width="100"
                                    ElementStyle="{StaticResource CenteredDataGridCell}"/>
                <DataGridTextColumn Header="Next Occurence"
                                    Binding="{Binding NextOccurance, StringFormat=d}"
                                    Width="120"
                                    ElementStyle="{StaticResource CenteredDataGridCell}"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</UserControl>
