<UserControl x:Class="BudgetApp.Views.PeopleView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:local="clr-namespace:BudgetApp.Views"
        xmlns:utility="clr-namespace:BudgetApp.Model.Utility"
        mc:Ignorable="d">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="auto"/>
        </Grid.RowDefinitions>
        
        <TextBlock 
            Grid.Row="0"
            FontSize="24"
            Text="People" />
        
        <Grid Grid.Row="1" Margin="0 25 0 0"
              utility:FocusHelper.FocusTarget="{Binding FocusTarget}">
            <Grid.RowDefinitions>
                <RowDefinition Height="auto"/>
                <RowDefinition Height="auto"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="167"/>
                <ColumnDefinition Width="167"/>
            </Grid.ColumnDefinitions>

            <TextBlock 
                Grid.Row="0" 
                Grid.Column="0" 
                Text="First Name"/>
            <TextBox 
                Grid.Row="1" 
                Grid.Column="0" 
                Margin="0 5 0 0"
                Text="{Binding FirstName, UpdateSourceTrigger=PropertyChanged}"
                utility:FocusHelper.FocusKey="FirstName"
                utility:FocusHelper.MoveCaretToEnd="True"/>

            <TextBlock 
                Grid.Row="0"
                Grid.Column="1"
                Margin="5 0 0 0"
                Text="Last Name"/>
            <TextBox 
                Grid.Row="1" 
                Grid.Column="1"
                Margin="5 5 0 0"
                Text="{Binding LastName, UpdateSourceTrigger=PropertyChanged}"
                utility:FocusHelper.FocusKey="LastName"
                utility:FocusHelper.MoveCaretToEnd="True"/>
        </Grid>

        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0 10 0 0">
            <Button
                Command="{Binding AddPersonCommand}"
                Content="Add"
                IsDefault="True"
                Width="81"/>
            <Button
                Margin="5 0 0 0"
                Command="{Binding RemovePersonCommand}"
                Content="Remove"
                Width="81"/>
            <Button
                Margin="5 0 0 0"
                Command="{Binding EditPersonCommand}"
                Content="Update Person"
                Width="97"/>
            <Button
                Margin="5 0 0 0"
                Command="{Binding CancelPersonCommand}"
                Content="Cancel"
                Width="60"/>
        </StackPanel>

        <DataGrid Grid.Row="3" 
                  Margin="0 10 0 0"
                  SelectionMode="Single"
                  ItemsSource="{Binding People}"
                  SelectedItem="{Binding SelectedPerson, Mode=TwoWay}"
                  AutoGenerateColumns="False"
                  CanUserResizeColumns="False"
                  HeadersVisibility="Column"
                  IsReadOnly="True">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Full Name"
                                    Binding="{Binding FullName}"
                                    Width="334"
                                    ElementStyle="{StaticResource CenteredDataGridCell}"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</UserControl>
