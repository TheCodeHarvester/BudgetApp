<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- Theme Colors -->
    <Color x:Key="PrimaryColor">#111113</Color>
    <Color x:Key="SecondaryColor">#3D3C38</Color>
    <Color x:Key="BorderColor">#A49F9D</Color>
    <Color x:Key="AccentColor">#ADD8E6</Color>
    <Color x:Key="TextColor">#FFFFFF</Color>

    <!-- Base Brushes -->
    <SolidColorBrush x:Key="PrimaryBrush" Color="{DynamicResource PrimaryColor}"/>
    <SolidColorBrush x:Key="SecondaryBrush" Color="{DynamicResource SecondaryColor}"/>
    <SolidColorBrush x:Key="BorderBrush" Color="{DynamicResource BorderColor}"/>
    <SolidColorBrush x:Key="AccentBrush" Color="{DynamicResource AccentColor}"/>
    <SolidColorBrush x:Key="TextBrush" Color="{DynamicResource TextColor}"/>

    <!-- Opacity Brushes -->
    <SolidColorBrush x:Key="PrimaryBrushOpacity25" Color="{DynamicResource PrimaryColor}" Opacity="0.25"/>

    <SolidColorBrush x:Key="SecondaryBrushOpacity10" Color="{DynamicResource SecondaryColor}" Opacity="0.1"/>
    <SolidColorBrush x:Key="SecondaryBrushOpacity20" Color="{DynamicResource SecondaryColor}" Opacity="0.2"/>
    <SolidColorBrush x:Key="SecondaryBrushOpacity30" Color="{DynamicResource SecondaryColor}" Opacity="0.3"/>
    <SolidColorBrush x:Key="SecondaryBrushOpacity50" Color="{DynamicResource SecondaryColor}" Opacity="0.6"/>

    <SolidColorBrush x:Key="AccentBrushOpacity50" Color="{DynamicResource AccentColor}" Opacity="0.5"/>

    <SolidColorBrush x:Key="TextBrushOpacity30" Color="{DynamicResource TextColor}" Opacity="0.3"/>
    <SolidColorBrush x:Key="TextBrushOpacity50" Color="{DynamicResource TextColor}" Opacity="0.5"/>
    <SolidColorBrush x:Key="TextBrushOpacity60" Color="{DynamicResource TextColor}" Opacity="0.6"/>
    <SolidColorBrush x:Key="TextBrushOpacity75" Color="{DynamicResource TextColor}" Opacity="0.75"/>
</ResourceDictionary>