<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:behaviors="clr-namespace:BudgetApp.Core.Behaviors">
    <!-- Date Picker Style -->
    <Style TargetType="DatePicker">
        <Setter Property="BorderThickness" Value="0.5"/>
        <Setter Property="behaviors:DatePickerBehavior.SelectAllOnFocus" Value="True"/>
        <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
        <Setter Property="Background" Value="{DynamicResource PrimaryBrush}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>

        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="DatePicker">
                    <Grid>
                        <Border
                            x:Name="RootBorder"
                            CornerRadius="5"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="30"/>
                                </Grid.ColumnDefinitions>

                                <DatePickerTextBox
                                    Margin="5"
                                    Grid.Column="0"
                                    x:Name="PART_TextBox"/>

                                <Button
                                    Grid.Column="1"
                                    x:Name="PART_Button"
                                    Background="{DynamicResource SecondaryBrushOpacity50}">
                                    <Viewbox Width="14" Height="14">
                                        <Path 
                                            StrokeThickness="1"
                                            Stroke="{DynamicResource TextBrush}"
                                            Data="M2 2 L12 2 L12 12 L2 12 L2 2
                                                  M2 4 L12 4
                                                  M7 6 L9 6
                                                  M5 2 L5 0
                                                  M9 2 L9 0"/>
                                    </Viewbox>
                                </Button>
                            </Grid>
                        </Border>

                        <!-- POPUP -->
                        <Popup 
                            x:Name="PART_Popup"
                            Placement="Bottom"
                            AllowsTransparency="True"
                            Focusable="False"
                            PopupAnimation="Fade">

                            <Border 
                                Padding="14"
                                CornerRadius="16"
                                BorderThickness="1"
                                Margin="0,8,0,0"
                                Background="{DynamicResource PrimaryBrush}"
                                BorderBrush="{DynamicResource BorderBrush}">

                                <Calendar 
                                    x:Name="PART_Calendar"
                                    Background="{DynamicResource PrimaryBrush}"
                                    Foreground="{DynamicResource TextBrush}"
                                    BorderBrush="{DynamicResource BorderBrush}"/>
                            </Border>
                        </Popup>
                    </Grid>

                    <ControlTemplate.Triggers>
                        <Trigger Property="IsKeyboardFocusWithin" Value="True">
                            <Setter TargetName="RootBorder" Property="BorderThickness" Value="2"/>
                            <Setter TargetName="PART_TextBox" Property="Margin" Value="5 3.5"/>
                            <Setter TargetName="RootBorder" Property="BorderBrush" 
                                    Value="{DynamicResource AccentBrush}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Date Picker TextBox Style -->
    <Style TargetType="DatePickerTextBox">
        <Setter Property="SelectionOpacity" Value="1"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
        <Setter Property="Background" Value="{DynamicResource PrimaryBrush}"/>
        <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
        <Setter Property="SelectionBrush" Value="{DynamicResource AccentBrush}"/>
        <Setter Property="SelectionTextBrush" Value="{DynamicResource TextBrush}"/>
        <Setter Property="behaviors:TextBoxBehavior.LoseFocusOnEnter" Value="True"/>
        <Setter Property="behaviors:TextBoxBehavior.SelectAllOnFocus" Value="True"/>

        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="DatePickerTextBox">
                    <Border BorderThickness="{TemplateBinding BorderThickness}">
                        <ScrollViewer x:Name="PART_ContentHost"/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
</ResourceDictionary>