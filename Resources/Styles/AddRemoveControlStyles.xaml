<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:custom="clr-namespace:BudgetApp.Core.CustomControls">

    <Style TargetType="custom:AddRemoveControl">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="custom:AddRemoveControl">
                    <StackPanel
                        Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Margin="0 0 0 0">

                        <Button
                            Width="30"
                            Height="30"
                            Command="{TemplateBinding AddCommand}">
                            <TextBlock
                                Text="+"
                                FontSize="24"
                                FontWeight="Bold"
                                TextAlignment="Justify"
                                VerticalAlignment="Stretch"
                                HorizontalAlignment="Stretch"
                                Margin="0 -6 0 0"/>
                        </Button>

                        <Button
                            Width="30"
                            Height="30"
                            Margin="1 0 0 0"
                            Command="{TemplateBinding RemoveCommand}">
                            <TextBlock
                                Text="-"
                                FontSize="24"
                                FontWeight="DemiBold"
                                TextAlignment="Justify"
                                VerticalAlignment="Stretch"
                                HorizontalAlignment="Stretch"
                                Margin="0 -6 0 0"/>
                        </Button>
                    </StackPanel>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
</ResourceDictionary>