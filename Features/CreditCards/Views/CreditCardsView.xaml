<UserControl x:Class="BudgetApp.Views.CreditCardsView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:custom="clr-namespace:BudgetApp.Core.CustomControls"
        mc:Ignorable="d"
        Background="{DynamicResource PrimaryBrush}">
    <DockPanel Style="{DynamicResource UserControlWrapper}">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
    
            <!-- Credit Cards List Section -->
            <Grid Grid.Column="0"
                Margin="20 0 0 0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="auto"/>
                    <RowDefinition Height="auto"/>
                </Grid.RowDefinitions>
    
                <GroupBox
                    Grid.Row="0">
                    <GroupBox.Header>
                        Credit Card Accounts
                    </GroupBox.Header>
        
                    <StackPanel>
                        <DataGrid 
                            Margin="0 5 0 0"
                            SelectionMode="Single"
                            ItemsSource="{Binding CreditCardAccounts}"
                            SelectedItem="{Binding SelectedCreditCard, Mode=TwoWay}"
                            AutoGenerateColumns="False"
                            CanUserResizeColumns="False"
                            HeadersVisibility="Column"
                            IsReadOnly="True">
                            <DataGrid.Columns>
                                <DataGridTextColumn
                                    Header="Owner"
                                    Binding="{Binding OwnerName}"
                                    Width="*"
                                    ElementStyle="{DynamicResource CenteredDataGridCell}"/>
                                <DataGridTextColumn 
                                    Header="Account Name"
                                    Binding="{Binding AccountName}"
                                    Width="*"
                                    ElementStyle="{DynamicResource CenteredDataGridCell}"/>
                            </DataGrid.Columns>
                        </DataGrid>
        
                        <custom:AddRemoveControl
                            AddCommand="{Binding AddCreditCardCommand}"
                            RemoveCommand="{Binding RemoveCreditCardCommand}"/>
                    </StackPanel>
                </GroupBox>
            </Grid>

            <!-- Selected Credit Card Account Section -->
            <StackPanel 
                Grid.Column="1"
                Margin="20 0"
                Grid.IsSharedSizeScope="True">

                <!-- Account Information Group Box -->
                <GroupBox>
                    <GroupBox.Header>
                        Account Information
                    </GroupBox.Header>
    
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="auto"/>
                            <RowDefinition Height="auto"/>
                            <RowDefinition Height="auto"/>
                            <RowDefinition Height="auto"/>
                            <RowDefinition Height="auto"/>
                            <RowDefinition Height="auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" SharedSizeGroup="FirstColumnGroup"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
    
                        <!-- Column 1 -->
                        <Label
                            Grid.Row="0"
                            Grid.Column="0"
                            Content="Owner"/>
                        <Label
                            Grid.Row="1"
                            Grid.Column="0"
                            Margin="0 5 0 0"
                            Content="Account Name"/>
                        <Label
                            Grid.Row="2"
                            Grid.Column="0"
                            Margin="0 5 0 0"
                            Content="Credit Card #"/>
                        <Label
                            Grid.Row="3"
                            Grid.Column="0"
                            Margin="0 5 0 0"
                            Content="ccv"/>
                        <Label
                            Grid.Row="4"
                            Grid.Column="0"
                            Margin="0 5 0 0"
                            Content="Cycle Date"/>
                        <Label
                            Grid.Row="5"
                            Grid.Column="0"
                            Margin="0 5 0 0"
                            Content="Expiration Date"/>
    
                        <!-- Column 2 -->
                        <ComboBox
                            Grid.Row="0"
                            Grid.Column="1"
                            Margin="5 0 0 0"
                            ItemsSource="{Binding People}"
                            SelectedValuePath="Id"
                            SelectedValue="{Binding SelectedCreditCard.OwnerId, Mode=TwoWay}"
                            DisplayMemberPath="FullName">
                        </ComboBox>
                        <TextBox
                            Grid.Row="1" 
                            Grid.Column="1"
                            Margin="5 5 0 0"
                            Text="{Binding SelectedCreditCard.AccountName, 
                            TargetNullValue='',
                            UpdateSourceTrigger=PropertyChanged}"/>
                        <TextBox
                            Grid.Row="2" 
                            Grid.Column="1"
                            Margin="5 5 0 0"
                            Text="{Binding AccountDetails.AccountNumber, 
                            TargetNullValue='',
                            Mode=TwoWay,
                            UpdateSourceTrigger=PropertyChanged}"/>
                        <TextBox
                            Grid.Row="3" 
                            Grid.Column="1"
                            Margin="5 5 0 0"
                            Text="{Binding AccountDetails.CCV, 
                            TargetNullValue='',
                            UpdateSourceTrigger=PropertyChanged}"/>
                        <TextBox 
                            Grid.Row="4"
                            Grid.Column="1"
                            Margin="5 5 0 0"
                            Text="{Binding SelectedCreditCard.Account.CycleDay, 
                            UpdateSourceTrigger=PropertyChanged}"/>
                        <DatePicker 
                            Grid.Row="5"
                            Grid.Column="1"
                            Margin="5 5 0 0"
                            SelectedDate="{Binding SelectedCreditCard.Account.ExpirationDate,
                            TargetNullValue='',
                            Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
    
                        <!-- Column 3 -->
                        <Button 
                            Grid.Row="2"
                            Grid.Column="2"
                            Margin="5 5 0 0"
                            Command="{Binding RemoveCreditCardCommand}"
                            Content="👁"/>
    
                        <!-- Column 4 -->
                        <Button 
                            Grid.Row="2"
                            Grid.Column="3"
                            Margin="5 5 0 0"
                            Command="{Binding RemoveCreditCardCommand}"
                            Content="📝"/>
                    </Grid>
                </GroupBox>
    
                <!-- Login Information Group Box -->
                <GroupBox
                    Margin="0 10 0 0">
                    <GroupBox.Header>
                        Login Information
                    </GroupBox.Header>
    
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="auto"/>
                            <RowDefinition Height="auto"/>
                            <RowDefinition Height="auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="auto" SharedSizeGroup="FirstColumnGroup"/>
                            <ColumnDefinition Width="200"/>
                            <ColumnDefinition Width="30"/>
                            <ColumnDefinition Width="30"/>
                        </Grid.ColumnDefinitions>
    
                        <!-- Column 1 -->
                        <Label
                            Grid.Row="0"
                            Grid.Column="0"
                            Content="Username"/>
                        <Label
                            Grid.Row="1"
                            Grid.Column="0"
                            Margin="0 5 0 0"
                            Content="Password"/>
                        <Label
                            Grid.Row="2"
                            Grid.Column="0"
                            Margin="0 5 0 0"
                            Content="Website URL"/>
    
                        <!-- Column 2 -->
                        <TextBox
                            Grid.Row="0" 
                            Grid.Column="1"
                            Margin="5 0 0 0"
                            Text="{Binding LoginDetails.Username,
                            TargetNullValue='',
                            UpdateSourceTrigger=PropertyChanged}"/>
                        <TextBox
                            Grid.Row="1" 
                            Grid.Column="1"
                            Margin="5 5 0 0"
                            Text="{Binding LoginDetails.Password,
                            TargetNullValue='',
                            UpdateSourceTrigger=PropertyChanged}"/>
                        <TextBox
                            Grid.Row="2" 
                            Grid.Column="1"
                            Margin="5 5 0 0"
                            Text="{Binding LoginDetails.WebsiteURL,
                            TargetNullValue='',
                            UpdateSourceTrigger=PropertyChanged}"/>
    
                        <!-- Column 3 -->
                        <Button 
                            Grid.Row="0"
                            Grid.Column="2"
                            Margin="5 0 0 0"
                            Command="{Binding RemoveCreditCardCommand}"
                            Content="&#xf070;"/>
                        <Button 
                            Grid.Row="1"
                            Grid.Column="2"
                            Margin="5 5 0 0"
                            Command="{Binding RemoveCreditCardCommand}"
                            Content="👁"/>
                        <Button 
                            Grid.Row="2"
                            Grid.Column="2"
                            Margin="5 5 0 0"
                            Command="{Binding RemoveCreditCardCommand}"
                            Content="🌐"/>
    
                        <!-- Column 4 -->
                        <Button 
                            Grid.Row="0"
                            Grid.Column="3"
                            Margin="5 0 0 0"
                            Command="{Binding RemoveCreditCardCommand}"
                            Content="📝"/>
                        <Button 
                            Grid.Row="1"
                            Grid.Column="3"
                            Margin="5 5 0 0"
                            Command="{Binding RemoveCreditCardCommand}"
                            Content="📝"/>
                    </Grid>
                </GroupBox>
    
                <!-- Money Information Group Box -->
                <GroupBox
                    Margin="0 10 0 0">
                    <GroupBox.Header>
                        Money Information
                    </GroupBox.Header>
    
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="auto"/>
                            <RowDefinition Height="auto"/>
                            <RowDefinition Height="auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="auto" 
                                              SharedSizeGroup="FirstColumnGroup"/>
                            <ColumnDefinition Width="200"/>
                        </Grid.ColumnDefinitions>
    
                        <!-- Column 1 -->
                        <Label
                            Grid.Row="0"
                            Grid.Column="0"
                            Content="Credit Line"/>
                        <Label
                            Grid.Row="1"
                            Grid.Column="0"
                            Margin="0 5 0 0"
                            Content="Balance"/>
                        <Label
                            Grid.Row="2"
                            Grid.Column="0"
                            Margin="0 5 0 0"
                            Content="Available"/>
    
                        <!-- Column 2 -->
                        <TextBox
                            Grid.Row="0" 
                            Grid.Column="1"
                            Margin="5 0 0 0"
                            Text="{Binding SelectedCreditCard.Account.CreditLine,
                            TargetNullValue='',
                            StringFormat={}{0:C},
                            UpdateSourceTrigger=LostFocus}"/>
                        <TextBox
                            Grid.Row="1"
                            Grid.Column="1"
                            Margin="5 5 0 0"
                            Text="{Binding SelectedCreditCard.Account.Balance,
                            TargetNullValue='',
                            StringFormat={}{0:C},
                            UpdateSourceTrigger=LostFocus}"/>
                        <Label
                            Grid.Row="2"
                            Grid.Column="1"
                            Margin="5 5 0 0"
                            Content="{Binding SelectedCreditCard.Account.Available,
                            TargetNullValue='',
                            StringFormat={}{0:C},
                            UpdateSourceTrigger=PropertyChanged}"/>
                    </Grid>
                </GroupBox>
    
                <!-- Interest Information Group Box -->
                <GroupBox>
                    <GroupBox.Header>
                        Interests
                    </GroupBox.Header>
                    
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="auto"/>
                            <RowDefinition Height="auto"/>
                        </Grid.RowDefinitions>
                        
                        <StackPanel
                            Grid.Row="1">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="auto"/>
                                    <ColumnDefinition Width="145"/>
                                    <ColumnDefinition Width="auto"/>
                                    <ColumnDefinition Width="95"/>
                                </Grid.ColumnDefinitions>
    
                                <Label
                                    Grid.Column="0"
                                    Content="Name"/>
                                <TextBox
                                    Grid.Column="1"
                                    Margin="5 0 0 0"
                                    Text="{Binding SelectedInterest.Name, 
                                Mode=TwoWay,
                                TargetNullValue='',
                                UpdateSourceTrigger=PropertyChanged}"
                                    IsEnabled="{Binding SelectedInterest}"/>
    
                                <Label
                                    Grid.Column="2"
                                    Content="Percentage"
                                    Margin="5 0 0 0"/>
                                <TextBox
                                    Grid.Column="3"
                                    Margin="5 0 0 0"
                                    Text="{Binding SelectedInterest.Percentage,
                                    Mode=TwoWay,
                                    TargetNullValue='',
                                    StringFormat={}{0:F2},
                                    UpdateSourceTrigger=LostFocus}"
                                    PreviewTextInput="NumberValidationTextBox"/>
                            </Grid>
    
                            <StackPanel>
                                <DataGrid
                                    Margin="0 5 0 0"
                                    SelectionMode="Single"
                                    ItemsSource="{Binding SelectedCreditCard.Account.Interests}"
                                    SelectedItem="{Binding SelectedInterest, Mode=TwoWay}"
                                    AutoGenerateColumns="False"
                                    CanUserResizeColumns="False"
                                    HeadersVisibility="Column"
                                    IsReadOnly="True">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn
                                            Width="*"
                                            Header="Name"
                                            Binding="{Binding Name}"
                                            ElementStyle="{DynamicResource CenteredDataGridCell}"/>
                                        <DataGridTextColumn
                                            Width="*"
                                            Header="Percentage"
                                            Binding="{Binding Percentage, StringFormat={}{0:#0.00'%'}}"
                                            ElementStyle="{DynamicResource CenteredDataGridCell}"/>
                                    </DataGrid.Columns>
                                </DataGrid>
    
                                <custom:AddRemoveControl
                                    AddCommand="{Binding AddInterestCommand}"
                                    RemoveCommand="{Binding RemoveInterestCommand}"/>
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                </GroupBox>
            </StackPanel>

            <!-- Selected Credit Card Notes Section -->
            <GroupBox
                Grid.Column="2"
                Header="Credit Card Notes"
                Margin="0 0 0 20">
                <StackPanel>
                    <DataGrid
                        Margin="0 5 0 0"
                        SelectionMode="Single"
                        ItemsSource="{Binding SelectedCreditCard.Account.Notes}"
                        SelectedItem="{Binding SelectedNote, Mode=TwoWay}"
                        AutoGenerateColumns="False"
                        CanUserResizeColumns="False"
                        CanUserAddRows="False"
                        CanUserDeleteRows="False"
                        HeadersVisibility="Column"
                        Style="{DynamicResource SingleClickEditDataCell}">
                        <DataGrid.Columns>
                            <DataGridTemplateColumn Header="Notes" Width="*">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Description}" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>

                                <DataGridTemplateColumn.CellEditingTemplate>
                                    <DataTemplate>
                                        <TextBox Text="{Binding Description, UpdateSourceTrigger=PropertyChanged}"
                                                 AcceptsReturn="True"
                                                 TextWrapping="Wrap"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellEditingTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>

                    <custom:AddRemoveControl
                        AddCommand="{Binding AddNoteCommand}"
                        RemoveCommand="{Binding RemoveNoteCommand}"/>
                </StackPanel>
            </GroupBox>
        </Grid>
    </DockPanel>
</UserControl>
