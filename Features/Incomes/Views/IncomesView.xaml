<UserControl x:Class="BudgetApp.Views.IncomesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:custom="clr-namespace:BudgetApp.Core.CustomControls"
             mc:Ignorable="d"
             Background="{DynamicResource PrimaryBrush}">
    <DockPanel Style="{DynamicResource UserControlWrapper}">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Income List Section -->
            <Grid Grid.Column="0"
                  Margin="0 0 20 50">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <GroupBox
                    Grid.Row="0" 
                    Header="Income List">
                    <DataGrid
                        IsReadOnly="True"
                        SelectionMode="Single"
                        HeadersVisibility="Column"
                        AutoGenerateColumns="False"
                        CanUserResizeColumns="False"
                        ItemsSource="{Binding Incomes}"
                        SelectedItem="{Binding SelectedIncome, Mode=TwoWay}">
                        <DataGrid.Columns>
                            <DataGridTextColumn
                                Header="Who's Income"
                                Binding="{Binding OwnerName}"
                                Width="*"
                                ElementStyle="{DynamicResource CenteredDataGridCell}"/>
                            <DataGridTextColumn 
                                Header="Source"
                                Binding="{Binding Account.IncomeSource}"
                                Width="*"
                                ElementStyle="{DynamicResource CenteredDataGridCell}"/>
                            <DataGridTextColumn 
                                Header="Amount"
                                Binding="{Binding Account.Amount, StringFormat={}{0:C}}"
                                Width="*"
                                ElementStyle="{DynamicResource CenteredDataGridCell}"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </GroupBox>
                <custom:AddRemoveControl
                    Grid.Row="1"
                    AddCommand="{Binding AddIncomeCommand}"
                    RemoveCommand="{Binding RemoveIncomeCommand}"/>
            </Grid>

            <!-- Selected Income Section -->
            <Grid Grid.Column="1" MinWidth="460">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <GroupBox
                    Grid.Row="0"
                    Header="Income List">

                    <Grid Margin="10 0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- First Column -->
                        <Label Grid.Row="0" Grid.Column="0" Content="Source"/>
                        <Label Grid.Row="1" Grid.Column="0" Margin="0 5 0 0" Content="Amount"/>
                        <Label Grid.Row="2" Grid.Column="0" Margin="0 5 0 0" Content="Who's Income"/>
                        <Label Grid.Row="3" Grid.Column="0" Margin="0 5 0 0" Content="Occurance Type"/>
                        <Label Grid.Row="4" Grid.Column="0" Margin="0 5 0 0" Content="Next Occurance"/>

                        <!-- Second Column -->
                        <TextBox 
                            Grid.Row="0" 
                            Grid.Column="1"
                            MaxLength="20"
                            Margin="5 0 0 0"
                            Text="{Binding SelectedIncome.Account.IncomeSource, 
                            UpdateSourceTrigger=PropertyChanged,
                            TargetNullValue=''}"/>
                        <TextBox 
                            Grid.Row="1"
                            Grid.Column="1"
                            MaxLength="20"
                            Margin="5 5 0 0"
                            Text="{Binding SelectedIncome.Account.Amount, 
                            StringFormat=C,
                            UpdateSourceTrigger=PropertyChanged,
                            TargetNullValue=''}"
                            PreviewTextInput="NumberValidationTextBox"/>
                        <ComboBox
                            Grid.Row="2"
                            Grid.Column="1"
                            Margin="5 5 0 0"
                            ItemsSource="{Binding People}"
                            SelectedValuePath="Id"
                            SelectedValue="{Binding SelectedIncome.OwnerId,
                            Mode=TwoWay}">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding FullName}"/>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                        <ComboBox
                            Grid.Row="3"
                            Grid.Column="1"
                            Margin="5 5 0 0"
                            ItemsSource="{Binding OccurenceTypes}"
                            SelectedItem="{Binding SelectedIncome.Account.OccurenceType, 
                            Mode=TwoWay,
                            UpdateSourceTrigger=PropertyChanged}">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Converter={StaticResource EnumDescriptionConverter}}"/>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                        <DatePicker 
                            Grid.Row="4"
                            Grid.Column="1"
                            Margin="5 5 0 0"
                            SelectedDate="{Binding SelectedIncome.Account.NextOccurrence, 
                                Mode=TwoWay,
                                TargetNullValue='',
                                UpdateSourceTrigger=PropertyChanged}"
                            CalendarStyle="{StaticResource ModernCalendar}"/>
                    </Grid>
                </GroupBox>
            </Grid>
        </Grid>
    </DockPanel>
</UserControl>
